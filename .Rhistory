scale_x_continuous(
breaks = seq(0, 25, by = 5),
expand = expansion(mult = c(0.02, 0.02)) # Un pequeño margen para que no se corte
) +
scale_y_continuous(
breaks = seq(0, 8, by = 2),
expand = expansion(mult = c(0, 0.05))
) +
coord_cartesian(ylim = c(0, 8)) +
# proporción alto/ancho
theme(aspect.ratio = 0.5)
