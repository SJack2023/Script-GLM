# 2. Función optimizada
plot_glm_completo <- function(preds, original_data, x_var, xtitle) {
ggplot() +
# Puntos observados con jitter
geom_jitter(data = original_data,
aes(x = .data[[x_var]], y = t_pa),
alpha = 0.2, size = 1.2, width = 0.2, color = "gray50") +
# Cinta de error (IC 95%)
geom_ribbon(data = preds,
aes(x = x, ymin = conf.low, ymax = conf.high),
fill = "#2c7fb8", alpha = 0.2) +
# Línea de tendencia
geom_line(data = preds,
aes(x = x, y = predicted),
color = "#2c7fb8", linewidth = 1) +
# Etiquetas y títulos
labs(x = xtitle, y = "Tamaño del parche (m)") +
# Estética profesional
theme_minimal(base_size = 11) +
theme(
panel.border = element_rect(colour = "black", fill = NA, linewidth = 0.8),
axis.text = element_text(color = "black"),
panel.grid.minor = element_blank(),
panel.grid.major = element_line(color = "gray96"),
axis.ticks = element_line(colour = "black")
)
}
# 3. Crear los gráficos individuales
p1 <- plot_glm_completo(pred_hd, datos_p, "hum_d", "Humedad D (%)")
p2 <- plot_glm_completo(pred_hf, datos_p, "hum_f", "Humedad F (%)")
p3 <- plot_glm_completo(pred_td, datos_p, "tem_d", "Temperatura D (°C)")
# 4. Combinación final con patchwork
plot_final <- (p1 + p2) / p3 +
plot_annotation(
title = "Efecto de las variables abióticas sobre el tamaño del parche",
subtitle = "",
theme = theme(
plot.title = element_text(size = 16, face = "bold", hjust = 0.5),
plot.subtitle = element_text(size = 12, hjust = 0.5, color = "gray30")
)
)
# Visualizar
print(plot_final)
