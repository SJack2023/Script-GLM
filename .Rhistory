str(s_pa)
View(s_pa)
hum_f2 <- s_pa$H_fue
hum_d2 <- s_pa$H_den
tem_d2 <- s_pa$T_den
tem_f2 <- s_pa$T_fue
pen2 <- s_pa$Pen
N_pa<- s_pa$N_par
N_in <- s_pa$N_ind
T_pa <- s_pa$T_par
test_h <- t.test(s_pa$H_den, s_pa$H_fue,
paired = TRUE,
conf.level = 0.95)
print(test_h)
test_te <- t.test(s_pa$T_den, s_pa$T_fue,
paired = TRUE,
conf.level = 0.95)
print(test_te)
